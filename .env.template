# ============================================================
# Sharon — Environment Variable Template
# ============================================================
# Copy this file to .env.local and fill in your values.
#
#   cp .env.template .env.local
#
# NEVER commit .env.local to git. It is already in .gitignore.
# ============================================================


# ------------------------------------------------------------
# Supabase
# Find these in: Supabase Dashboard → Project Settings → API
# ------------------------------------------------------------

# Project URL  (e.g. https://xxxxxxxxxxxxxxxxxxxx.supabase.co)
VITE_SUPABASE_URL=

# Public / anon key — safe to expose to the browser
VITE_SUPABASE_ANON_KEY=

# Service role key — KEEP SECRET, used only by server-side scripts
# Supabase Dashboard → Project Settings → API → service_role (secret)
SUPABASE_SERVICE_ROLE_KEY=

# Direct database connection URI — used by migration / seed scripts
# Supabase Dashboard → Project Settings → Database → Connection string (URI mode)
SUPABASE_DB_URL=


# ------------------------------------------------------------
# OpenAI
# Find this at: https://platform.openai.com → API Keys
# ------------------------------------------------------------

# Used client-side for embeddings and AI chat completions
# NOTE: Move to a server/edge function before deploying to production
VITE_OPENAI_API_KEY=


# ------------------------------------------------------------
# Anthropic / Claude
# Find this at: https://console.anthropic.com → API Keys
# ------------------------------------------------------------

# Server-only secret. Used by the /api/claude proxy and /api/agent function.
# DO NOT prefix with VITE_ — Vite inlines any VITE_-prefixed env var into the
# browser bundle, which would expose this key to anyone who views the source.
CLAUDE_API_KEY=


# ------------------------------------------------------------
# LaunchDarkly
# ------------------------------------------------------------

# Client-side environment ID — safe for browser (NOT the SDK key)
# app.launchdarkly.com → your project → Environments → click env → Client-side ID
VITE_LAUNCHDARKLY_CLIENT_ID=

# Server-side SDK key — KEEP SECRET, used by /api/agent for AI Config evaluation
# This is what populates the AI Config Monitoring tab. Server-side only.
LAUNCHDARKLY_SDK_KEY=

# Admin/server API key — KEEP SECRET, used by scripts and MCP tooling only
Launchdarkly_API_KEY=


# ------------------------------------------------------------
# Tavily — web search for the SE Researcher agent
# Free tier: 1,000 queries/month — get at https://tavily.com
# Server-side only.
# ------------------------------------------------------------

TAVILY_API_KEY=


# ------------------------------------------------------------
# Server hardening — comma-separated list of allowed Origins for /api/*
# Defaults to localhost dev ports. In production set this to your domain(s).
# Example: ALLOWED_ORIGINS=https://sharon.example.com,https://sharon-staging.vercel.app
# ------------------------------------------------------------

ALLOWED_ORIGINS=
